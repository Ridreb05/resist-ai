# ── ResistAI Backend Environment Variables ──────────────────────────────────
# Copy this file to .env and fill in real values

APP_NAME=ResistAI
APP_VERSION=1.0.0
ENVIRONMENT=development
DEBUG=false

HOST=0.0.0.0
PORT=8000

# Database — use PostgreSQL in production
# DATABASE_URL=postgresql+asyncpg://user:password@db:5432/resistai
DATABASE_URL=sqlite+aiosqlite:///./resistai.db

# Redis (optional — for caching & Celery)
REDIS_URL=redis://localhost:6379/0

# SECURITY — CHANGE THIS IN PRODUCTION (openssl rand -hex 32)
SECRET_KEY=CHANGE_ME_IN_PRODUCTION_USE_LONG_RANDOM_STRING_AT_LEAST_32_CHARS
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# CORS — comma-separated list of allowed origins
ALLOWED_ORIGINS=["http://localhost:3000","http://localhost:5173"]

# ML
MODEL_DIR=./ml_models
MODEL_VERSION=v1

# Rate Limiting
RATE_LIMIT_PER_MINUTE=60
